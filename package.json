{
  "name": "gala",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.admin.config.js && vite build --config vite.sponsors.config.js",
    "preview": "vite preview",
    "qa:install": "playwright install chromium",
    "qa:smoke": "playwright test -c qa/playwright.config.js qa/smoke.spec.js",
    "qa:visual": "playwright test -c qa/playwright.config.js qa/visual.spec.js",
    "qa:visual:update": "playwright test -c qa/playwright.config.js qa/visual.spec.js --update-snapshots",
    "qa:a11y": "playwright test -c qa/playwright.config.js qa/a11y.spec.js",
    "qa:parity": "playwright test -c qa/playwright.config.js qa/shell-parity.spec.js",
    "qa:stress": "node qa/api-stress.mjs --yes",
    "qa:lighthouse": "node qa/performance.mjs",
    "qa:webpagetest": "node qa/webpagetest.mjs",
    "qa:all": "npm run qa:smoke && npm run qa:a11y && npm run qa:parity && (npm run qa:visual || true) && npm run qa:lighthouse && npm run qa:stress",
    "build:admin": "vite build --config vite.admin.config.js",
    "build:sponsors": "vite build --config vite.sponsors.config.js"
  },
  "dependencies": {
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.3.3",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^13.2.0",
    "vite": "^5.4.21"
  }
}
